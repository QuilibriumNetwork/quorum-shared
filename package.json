{
  "name": "@quilibrium/quorum-shared",
  "version": "2.1.0-3",
  "description": "Shared types, hooks, and utilities for Quorum mobile and desktop apps",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.native.js",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.native.js"
      },
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@noble/hashes": "^1.3.0",
    "dayjs": "^1.11.19",
    "multiformats": "^13.3.1",
    "unified": "^11.0.0",
    "remark-parse": "^11.0.0",
    "remark-gfm": "^4.0.1",
    "remark-stringify": "^11.0.0",
    "strip-markdown": "^6.0.0"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.19.0",
    "@tabler/icons-react": ">=3.0.0",
    "@tabler/icons-react-native": ">=3.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "clsx": ">=2.0.0",
    "expo-document-picker": ">=12.0.0",
    "expo-haptics": ">=13.0.0",
    "expo-image-picker": ">=15.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-dropzone": ">=14.0.0",
    "react-native": ">=0.81.0",
    "react-tooltip": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "@tabler/icons-react": {
      "optional": true
    },
    "@tabler/icons-react-native": {
      "optional": true
    },
    "clsx": {
      "optional": true
    },
    "expo-document-picker": {
      "optional": true
    },
    "expo-haptics": {
      "optional": true
    },
    "expo-image-picker": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-dropzone": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-tooltip": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@lingui/core": "^4.14.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tabler/icons-react": "^3.40.0",
    "@tabler/icons-react-native": "^3.40.0",
    "@tanstack/react-query": "^5.62.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.16",
    "clsx": "^2.0.0",
    "expo-document-picker": "^55.0.8",
    "expo-haptics": "^55.0.8",
    "expo-image-picker": "^55.0.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.4.1",
    "react-native": "^0.81.5",
    "react-native-safe-area-context": "^5.7.0",
    "react-tooltip": "^5.30.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "quorum",
    "chat",
    "shared"
